# Copy this file to .env and fill in your own values. Never commit .env.

# Flask
SECRET_KEY=replace-with-a-long-random-string
FLASK_DEBUG=False

# Database (defaults to local SQLite if unset)
DATABASE_URL=sqlite:///furniture.db

# Admin account created on first run
ADMIN_EMAIL=admin@maisonliban.com
ADMIN_PASSWORD=choose-a-strong-password

# Groq API key for the AI shopping assistant -> https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
